{
  "id": null,
  "uid": "supersale-overview",
  "title": "SuperSale API - Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP p95 latency (s) by URI",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RPS by URI",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx error rate %",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count[5m]))",
          "legendFormat": "error%",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Used (bytes)",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "heap used",
          "refId": "A"
        }
      ]
    }
  ]
}
